@model DataService.UI.Models.OrderListViewModel
@{
    ViewData["Title"] = "Orders";
    var startItem = Model.TotalCount == 0 ? 0 : (Model.Page - 1) * Model.PageSize + 1;
    var endItem = Math.Min(Model.Page * Model.PageSize, Model.TotalCount);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Orders</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Order</a>
</div>

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto flex-grow-1">
        <label for="search" class="form-label visually-hidden">Search orders</label>
        <input type="text"
               id="search"
               name="search"
               class="form-control"
               placeholder="Search by customer, product, or status..."
               value="@Model.Search" />
    </div>
    <div class="col-auto">
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (!string.IsNullOrWhiteSpace(Model.Search))
        {
            <a asp-action="Index" asp-route-pageSize="@Model.PageSize" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

@if (Model.TotalCount == 0)
{
    <div class="alert alert-info">
        @(string.IsNullOrWhiteSpace(Model.Search) ? "No orders found." : "No orders match your search.")
    </div>
}
else
{
    <p class="text-muted small mb-2">Showing @startItem–@endItem of @Model.TotalCount orders</p>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Customer</th>
                <th>Product</th>
                <th>Qty</th>
                <th>Unit Price</th>
                <th>Total</th>
                <th>Order Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.CustomerName</td>
                    <td>@order.Product</td>
                    <td>@order.Quantity</td>
                    <td>@order.UnitPrice.ToString("C")</td>
                    <td>@order.TotalPrice.ToString("C")</td>
                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <span class="badge @GetStatusBadge(order.Status)">@order.Status</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Orders pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    @if (Model.HasPreviousPage)
                    {
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-page="@(Model.Page - 1)"
                           asp-route-pageSize="@Model.PageSize">Previous</a>
                    }
                    else
                    {
                        <span class="page-link">Previous</span>
                    }
                </li>

                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    @if (Model.HasNextPage)
                    {
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-search="@Model.Search"
                           asp-route-page="@(Model.Page + 1)"
                           asp-route-pageSize="@Model.PageSize">Next</a>
                    }
                    else
                    {
                        <span class="page-link">Next</span>
                    }
                </li>
            </ul>
        </nav>
    }
}

@functions {
    string GetStatusBadge(string status) => status switch
    {
        "Delivered"  => "bg-success",
        "Shipped"    => "bg-primary",
        "Processing" => "bg-warning text-dark",
        "Cancelled"  => "bg-danger",
        _            => "bg-secondary"
    };
}
