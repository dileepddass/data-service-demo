@model IEnumerable<DataService.UI.Models.Order>
@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Orders</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Order</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No orders found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Customer</th>
                <th>Product</th>
                <th>Qty</th>
                <th>Unit Price</th>
                <th>Total</th>
                <th>Order Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.CustomerName</td>
                    <td>@order.Product</td>
                    <td>@order.Quantity</td>
                    <td>@order.UnitPrice.ToString("C")</td>
                    <td>@order.TotalPrice.ToString("C")</td>
                    <td>@order.OrderDate.ToString("dd MMM yyyy")</td>
                    <td>
                        <span class="badge @GetStatusBadge(order.Status)">@order.Status</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@order.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@functions {
    string GetStatusBadge(string status) => status switch
    {
        "Delivered"  => "bg-success",
        "Shipped"    => "bg-primary",
        "Processing" => "bg-warning text-dark",
        "Cancelled"  => "bg-danger",
        _            => "bg-secondary"
    };
}
